# =====================================================================
# Copia este archivo como ".env" (sin .example) y rellena tus valores reales.
# Nunca subas el archivo ".env" real a git.
# =====================================================================

# --- Servidor ---
PORT=8080

# --- Arquitectura: Nube/Nube ---
# Este proyecto esta pensado para desplegarse con TODO en la nube:
#   - Backend (este servidor) -> un PaaS en la nube (Render, Railway, Cloud Run, etc.)
#   - Base de datos           -> Oracle Cloud (Autonomous Database), no Oracle XE local
#   - Frontend                -> hosting estatico en la nube (Vercel, Netlify, etc.)
# Ver ARCHITECTURE.md para el diagrama y la explicacion completa.

# --- Oracle (Cloud) ---
# Si usas Oracle Cloud Autonomous Database, el connect string viene del
# archivo "wallet" que descargas desde tu consola de Oracle Cloud (OCI),
# normalmente algo como: midb_high, midb_medium, etc. (alias del tnsnames.ora
# que trae el wallet). Si todavia trabajas en local con Oracle XE, deja
# localhost:1521/XE para probar antes de migrar a la nube.
ORACLE_CONNECT_STRING=localhost:1521/XE

# --- Credenciales de Oracle CIFRADAS (recomendado) ---
# 1) Genera tu clave maestra:      node scripts/generate-key.js
# 2) Cifra tu usuario/password:    node scripts/encrypt-credentials.js <usuario> <password>
# 3) Pega el resultado aqui abajo (y borra las variables en texto plano):
ENCRYPTION_KEY=
ORACLE_USER_ENC=
ORACLE_PASSWORD_ENC=

# --- (Solo para pruebas rapidas en local, evitar en produccion) ---
# Si NO defines las variables *_ENC de arriba, el backend usa estas en
# texto plano y muestra una advertencia en consola.
ORACLE_USER=system
ORACLE_PASSWORD=tu_password_de_oracle

# --- Autenticacion de usuarios de la app (login) ---
# Clave para firmar los JWT que se entregan al hacer login.
# Generala igual que ENCRYPTION_KEY (puede ser otra corrida de generate-key.js).
JWT_SECRET=

# --- Google Cloud (Pub/Sub + FCM) ---
# Pon esto en "false" mientras no tengas un proyecto GCP creado.
# El backend funcionará igual: solo registrará en consola que "se habria enviado"
# la notificación, sin fallar ni bloquear el guardado en Oracle.
GCP_ENABLED=false

GCP_PROJECT_ID=tu-proyecto-gcp
GCP_PUBSUB_TOPIC=topico-movimientos
# Ruta al archivo JSON de la cuenta de servicio (lo descargas desde GCP/Firebase)
GOOGLE_APPLICATION_CREDENTIALS=./credentials/service-account.json
